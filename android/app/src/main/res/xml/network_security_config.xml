<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext for API feeds -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">eporner.com</domain>
        <domain includeSubdomains="true">redtube.com</domain>
        <domain includeSubdomains="true">xvideos.com</domain>
    </domain-config>
</network-security-config>
